# ─── FitCoach – Environment Variables ───────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# Base URL of the backend REST API (leave blank to use mock data)
VITE_API_BASE_URL=

# Set to "false" to disable mock data and require a real API
VITE_USE_MOCK_DATA=true

# EmailJS – credenciais do serviço de envio de e-mail gratuito
# Crie uma conta em https://www.emailjs.com e preencha abaixo
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# Override de destinatário para testes (remova ou deixe vazio em produção)
VITE_EMAILJS_TEST_TO=

