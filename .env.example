# ─── Movr – Environment Variables ───────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Supabase (required)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Sentry – error monitoring (optional, but recommended in production)
# Create a project at https://sentry.io and paste the DSN below.
VITE_SENTRY_DSN=

# Stripe – payments (optional until payment features are live)
# Get your publishable key at https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=

# App URL – used for OAuth redirects (defaults to window.location.origin if omitted)
VITE_APP_URL=http://localhost:5173

